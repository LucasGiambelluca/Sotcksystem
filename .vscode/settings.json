{
    "deno.enable": true,
    "deno.enablePaths": [
        "supabase/functions"
    ],
    "deno.config": "./supabase/functions/deno.json",
    "deno.unstable": true,
    "deno.lint": true,
    "typescript.validate.enable": true,
    "search.exclude": {
        "**/node_modules": true,
        "**/node_modules_old": true,
        "**/dist": true,
        "**/build": true,
        "**/.git": true,
        "**/.next": true,
        "**/supabase/.temp": true,
        "**/whatsapp-server/auth_info_baileys": true,
        "**/whatsapp-server/auth_test": true
    },
    "files.exclude": {
        "**/node_modules": true,
        "**/node_modules_old": true,
        "**/dist": true,
        "**/build": true,
        "**/.git": true,
        "**/.next": true,
        "**/supabase/.temp": true
    },
    "files.watcherExclude": {
        "**/node_modules/**": true,
        "**/node_modules_old/**": true,
        "**/dist/**": true,
        "**/build/**": true,
        "**/.git/objects/**": true
    }
}
