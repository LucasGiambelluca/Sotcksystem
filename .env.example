# ==========================================
# StockSystem — Variables de Entorno
# Copia este archivo como .env y completá con tus valores reales
# ==========================================

# ==========================================
# FRONTEND (Build-time: se hornean en el bundle)
# ==========================================
# URL PÚBLICA del backend, tal como la ve el navegador del usuario
# Local:        http://localhost:3001
# Producción:   https://api.tudominio.com   (o https://tudominio.com si usás proxy Nginx)
VITE_API_URL=http://localhost:3001

# Supabase - copiá desde: Supabase → Project Settings → API
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ==========================================
# BACKEND (Runtime: leídas por Node.js)
# ==========================================

# Supabase URLs y claves — copiá desde: Supabase → Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJ...anon-key...             # anon key
SUPABASE_SERVICE_KEY=eyJ...service-role... # ⚠️  service_role key (NUNCA expongas esto en el frontend)

# Connection string de Supabase → Project Settings → Database → URI
DATABASE_URL=postgresql://postgres:[TU-PASSWORD]@db.xxxx.supabase.co:5432/postgres

# ==========================================
# SEGURIDAD
# ==========================================
# Generá un string aleatorio largo y único. Ejemplo (PowerShell):
#   -join ((65..90 + 97..122 + 48..57) * 10 | Get-Random -Count 64 | %{[char]$_})
# Ejemplo (bash):
#   openssl rand -hex 32
JWT_SECRET=cambia-esto-por-un-string-largo-y-aleatorio-minimo-32-caracteres

# Orígenes permitidos para CORS (separados por coma si hay más de uno)
# Local:        http://localhost:8080
# Producción:   https://panel.tudominio.com
CORS_ORIGIN=http://localhost:8080

# URL pública del frontend (usada en links enviados por el bot)
FRONTEND_URL=http://localhost:8080

# ==========================================
# REDIS (interno Docker — no modificar en producción con docker-compose)
# ==========================================
REDIS_URL=redis://redis:6379

# ==========================================
# BAILEYS / WHATSAPP
# (manejado automáticamente por Docker volumes — no modificar)
# ==========================================
BAILEYS_SESSION_PATH=/app/sessions/auth_info_baileys
BAILEYS_STORE_PATH=/app/sessions/baileys_store.json

# ==========================================
# OPCIONALES
# ==========================================
# Google Maps API Key (para geocoding en rutas)
GOOGLE_MAPS_API_KEY=

# Puerto del servidor backend
PORT=3001
NODE_ENV=production
